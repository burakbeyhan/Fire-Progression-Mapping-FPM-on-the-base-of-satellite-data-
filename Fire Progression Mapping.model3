    <Option name="HELP_URL" type="invalid"/>
    <Option name="SHORT_DESCRIPTION" type="invalid"/>
    <Option value="This is the raster grid layer showing the FPMs according to the number of days representing also the fraction of time." name="fpm__raster" type="QString"/>
    <Option value="This is the vector layer showing the FPMs according to the number of specified intervals." name="fpm__vector" type="QString"/>
    <Option value="Include AFs with high level of confidence" name="high" type="QString"/>
    <Option value="Include AFs with low level of confidence" name="low" type="QString"/>
    <Option value="Include AFs with nominal level of confidence" name="nominal" type="QString"/>
    <Option name="select_the_layer_covering_selected_active_fires" type="invalid"/>
    <Option name="select_the_layer_showing_delimited_fire_zones_doundaries" type="invalid"/>
    <Option value="Once a value is specified for the interval length, the option defined for the number of intervals will not be operational as the number of intervals will be calculated according to the specified lenght of interval. You can defined the length of interval as below;&#xa;&#xa;1 → 1 hour&#xa;1.5 → 1 hour and 30 minutes&#xa;1.25 → 1 hour and 15 minutes&#xa;1.125 → 1 hour and 7 minutes and 30 seconds" name="specify_the_length_of_each_interval" type="QString"/>
    <Option name="specify_the_number_of_intervals_for_the_fire_progressing_map" type="invalid"/>
  </Option>
  <Option value="Version2" name="internal_version" type="QString"/>
  <Option name="modelVariables"/>
  <Option value="FPM" name="model_group" type="QString"/>
  <Option value="Production of Fire Progression Maps" name="model_name" type="QString"/>
  <Option value="" name="outputGroup" type="QString"/>
  <Option name="outputOrder"/>
  <Option name="parameterDefinitions" type="Map">
    <Option name="fpm__raster" type="Map">
      <Option value="true" name="create_by_default" type="bool"/>
      <Option name="default" type="invalid"/>
      <Option name="defaultGui" type="invalid"/>
      <Option value="FPM - Raster" name="description" type="QString"/>
      <Option value="0" name="flags" type="int"/>
      <Option value="" name="help" type="QString"/>
      <Option name="metadata" type="Map">
        <Option value="sagang:cliprasterwithpolygon_1" name="_modelChildId" type="QString"/>
        <Option value="FPM - Raster" name="_modelChildOutputName" type="QString"/>
        <Option value="sagang" name="_modelChildProvider" type="QString"/>
      </Option>
      <Option value="fpm__raster" name="name" type="QString"/>
      <Option value="rasterDestination" name="parameter_type" type="QString"/>
      <Option value="false" name="supports_non_file_outputs" type="bool"/>
    </Option>
    <Option name="fpm__vector" type="Map">
      <Option value="true" name="create_by_default" type="bool"/>
      <Option value="-1" name="data_type" type="int"/>
      <Option name="default" type="QgsProcessingOutputLayerDefinition">
        <Option type="Map">
          <Option name="create_options" type="Map">
            <Option value="UTF-8" name="fileEncoding" type="QString"/>
          </Option>
          <Option name="sink" type="Map">
            <Option value="true" name="active" type="bool"/>
            <Option value="1" name="type" type="int"/>
            <Option value="TEMPORARY_OUTPUT" name="val" type="QString"/>
          </Option>
        </Option>
      </Option>
      <Option name="defaultGui" type="invalid"/>
      <Option value="FPM - Vector" name="description" type="QString"/>
      <Option value="0" name="flags" type="int"/>
      <Option value="" name="help" type="QString"/>
      <Option name="metadata" type="Map">
        <Option value="native:fieldcalculator_2" name="_modelChildId" type="QString"/>
        <Option value="FPM - Vector" name="_modelChildOutputName" type="QString"/>
        <Option value="native" name="_modelChildProvider" type="QString"/>
      </Option>
      <Option value="fpm__vector" name="name" type="QString"/>
      <Option value="sink" name="parameter_type" type="QString"/>
      <Option value="true" name="supports_append" type="bool"/>
      <Option value="true" name="supports_non_file_outputs" type="bool"/>
    </Option>
    <Option name="include_afs_with_high_level_of_confidence" type="Map">
      <Option value="true" name="default" type="bool"/>
      <Option name="defaultGui" type="invalid"/>
